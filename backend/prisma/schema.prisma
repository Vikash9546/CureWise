// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  email               String               @unique
  username            String?              @unique
  firstName           String?
  lastName            String?
  password            String?
  role                String               // "ADMIN" | "CUSTOMER"
  
  // Reputation & Activity
  points              Int                  @default(0)
  streak              Int                  @default(0)
  lastStreakDate      DateTime?
  badges              String[]             @default(["beginner"])
  
  // Relations
  doctorAppointments  DoctorAppointment[]  @relation("PatientAppointments")
  ambulanceBookings   AmbulanceBooking[]   @relation("UserAmbulance")
  meetings            Meeting[]            @relation("UserMeetings")
  posts               Post[]               @relation("UserPosts")
  comments            Comment[]            @relation("UserComments")
  likes               Like[]               @relation("UserLikes")
  wellnessPlans       WellnessPlan[]       @relation("UserWellnessPlans")
  
  // Tracking arrays for quick lookup
  likedPostIds        String[]             @default([])
  savedPostIds        String[]             @default([])
  
  createdAt           DateTime?            @default(now())
}

model Doctor {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  specialty       String
  experience      Int       // Years
  consultancyFee  Float
  rating          Float     @default(4.5)
  imageUrl        String?
  hospitalName    String?
  city            String?
  lat             Float?
  lon             Float?
  appointments    DoctorAppointment[]
  createdAt       DateTime  @default(now())
}

model DoctorAppointment {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  user            User      @relation("PatientAppointments", fields: [userId], references: [id])
  userId          String    @db.ObjectId
  doctor          Doctor    @relation(fields: [doctorId], references: [id])
  doctorId        String    @db.ObjectId
  patientName     String
  patientAge      Int
  specialty       String    
  appointmentDate DateTime
  notes           String?
  paymentStatus   String    @default("PENDING") 
  paymentAmount   Float
  status          String    @default("PENDING") 
  createdAt       DateTime  @default(now())
}

model AmbulanceBooking {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  user          User      @relation("UserAmbulance", fields: [userId], references: [id])
  userId        String    @db.ObjectId
  patientName   String
  location      String
  contactNumber String
  emergencyType String    
  status        String    @default("REQUESTED") 
  notes         String?
  createdAt     DateTime  @default(now())
}

model Meeting {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  user          User      @relation("UserMeetings", fields: [userId], references: [id])
  userId        String    @db.ObjectId
  title         String
  description   String?
  meetingDate   DateTime
  duration      Int       @default(30) 
  type          String    @default("video") 
  meetLink      String?
  invitees      String[]  @default([])
  status        String    @default("SCHEDULED") 
  createdAt     DateTime  @default(now())
}

model Post {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  author        User      @relation("UserPosts", fields: [authorId], references: [id])
  authorId      String    @db.ObjectId
  type          String    // "STORY" | "DISCUSSION"
  category      String
  title         String
  content       String    
  headline      String?
  initialState  String?   
  currentState  String?   
  duration      String?   
  tags          String[]  @default([])
  likesCount    Int       @default(0)
  isVerified    Boolean   @default(false)
  isAnonymous   Boolean   @default(false)
  comments      Comment[]
  likes         Like[]
  createdAt     DateTime  @default(now())
}

model Comment {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  author        User      @relation("UserComments", fields: [authorId], references: [id])
  authorId      String    @db.ObjectId
  post          Post      @relation(fields: [postId], references: [id])
  postId        String    @db.ObjectId
  text          String
  likesCount    Int       @default(0)
  isStory       Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

model Like {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  user          User      @relation("UserLikes", fields: [userId], references: [id])
  userId        String    @db.ObjectId
  post          Post?     @relation(fields: [postId], references: [id])
  postId        String?   @db.ObjectId
  commentId     String?   @db.ObjectId
  createdAt     DateTime  @default(now())
}

model WellnessPlan {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  user          User      @relation("UserWellnessPlans", fields: [userId], references: [id])
  userId        String    @db.ObjectId
  assessment    Json?     
  plan          Json?     
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}
