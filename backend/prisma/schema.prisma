// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  email               String               @unique
  firstName           String?
  lastName            String?
  password            String?
  role                String               // "ADMIN" | "CUSTOMER"
  doctorAppointments  DoctorAppointment[]  @relation("PatientAppointments")
  ambulanceBookings   AmbulanceBooking[]   @relation("UserAmbulance")
  meetings            Meeting[]            @relation("UserMeetings")
}

model Doctor {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  specialty       String
  experience      Int       // Years
  consultancyFee  Float
  rating          Float     @default(4.5)
  imageUrl        String?
  hospitalName    String?
  city            String?
  lat             Float?
  lon             Float?
  appointments    DoctorAppointment[]
  createdAt       DateTime  @default(now())
}

model DoctorAppointment {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  user            User      @relation("PatientAppointments", fields: [userId], references: [id])
  userId          String    @db.ObjectId
  doctor          Doctor    @relation(fields: [doctorId], references: [id])
  doctorId        String    @db.ObjectId
  patientName     String
  patientAge      Int
  specialty       String    // Redundant but helpful if doctor is deleted
  appointmentDate DateTime
  notes           String?
  paymentStatus   String    @default("PENDING") // "PENDING", "COMPLETED"
  paymentAmount   Float
  status          String    @default("PENDING") // "PENDING", "CONFIRMED", "CANCELLED"
  createdAt       DateTime  @default(now())
}

model AmbulanceBooking {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  user          User      @relation("UserAmbulance", fields: [userId], references: [id])
  userId        String    @db.ObjectId
  patientName   String
  location      String
  contactNumber String
  emergencyType String    // "Accident", "Heart Attack", "Stroke", "Other"
  status        String    @default("REQUESTED") // "REQUESTED", "DISPATCHED", "ARRIVED", "COMPLETED"
  notes         String?
  createdAt     DateTime  @default(now())
}

model Meeting {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  user          User      @relation("UserMeetings", fields: [userId], references: [id])
  userId        String    @db.ObjectId
  title         String
  description   String?
  meetingDate   DateTime
  duration      Int       @default(30) // minutes
  type          String    @default("video") // "video" | "audio"
  meetLink      String?
  invitees      String[]  @default([])
  status        String    @default("SCHEDULED") // "SCHEDULED", "CANCELLED"
  createdAt     DateTime  @default(now())
}
